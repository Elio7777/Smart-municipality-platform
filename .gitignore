# ============================================
# Secrets — NEVER commit these
# ============================================
.env
.env.local
.env.*.local

# ============================================
# Dependencies
# ============================================
node_modules
.pnp
.pnp.js

# ============================================
# Build output
# ============================================
dist
dist-ssr
dev-dist
build
*.local

# ============================================
# Vite cache
# ============================================
.vite

# ============================================
# User-uploaded files (runtime data, not code)
# ============================================
uploads/*
!uploads/.gitkeep

# ============================================
# Logs
# ============================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Editor / IDE
# ============================================
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ============================================
# OS files
# ============================================
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================
# Test coverage (if you add tests later)
# ============================================
coverage
*.lcov
